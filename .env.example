APP_NAME=MooTask
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mootask
DB_USERNAME=root
DB_PASSWORD=

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Swoole Configuration
LARAVEL_SWS_HTTP_HOST=0.0.0.0
LARAVEL_SWS_HTTP_PORT=5200

# JWT Configuration
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# File Upload Configuration
FILESYSTEM_DRIVER=local
UPLOAD_MAX_SIZE=104857600
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,zip,rar

# WebSocket Configuration
WEBSOCKET_SERVER=laravels
WEBSOCKET_PORT=5201

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=mootask_

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Search Engine Configuration
MANTICORE_HOST=127.0.0.1
MANTICORE_PORT=9312
